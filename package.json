    "mysql": "^2.18.1",
    "mysql2": "^3.15.3",
    "pdfkit": "^0.17.2",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/jest": "^30.0.0",
    "@types/mysql": "^2.15.27",
    "@types/node": "^22.19.2",
    "@types/pdfkit": "^0.17.4",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "jest": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
